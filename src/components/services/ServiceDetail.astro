---
import type { Service } from '../../data/services';
import { formatPrice } from '../../data/services';

interface Props {
  service: Service;
}
const { service } = Astro.props;

const priceLabel =
  service.priceUnit === 'mes'
    ? `desde ${formatPrice(service.priceFrom)}€/mes`
    : `desde ${formatPrice(service.priceFrom)}€`;
---

<article class="container-site service-page">
  <header class="service-header" data-reveal-group>
    <nav class="service-breadcrumb" aria-label="Breadcrumb" data-reveal>
      <a href="/servicios">~/servicios</a>
      <span aria-hidden="true">/</span>
      <span>{service.slug}</span>
    </nav>
    <h1 class="service-title" data-reveal>{service.title}</h1>
    <p class="service-price" data-reveal>{priceLabel}</p>
    <p class="service-answer" data-reveal>{service.answerFirst}</p>
    <a class="btn-terminal btn-terminal--primary service-header-cta" href="/#contacto" data-reveal>
      <span class="bracket bracket-l" aria-hidden="true">[</span>
      pedir_presupuesto
      <span class="bracket bracket-r" aria-hidden="true">]</span>
    </a>
  </header>

  <section class="service-section" aria-labelledby="incluye" data-reveal-group>
    <h2 class="service-section-title" id="incluye" data-reveal>
      <span class="service-prompt" aria-hidden="true">$</span> ls incluye/
    </h2>
    <ul class="service-deliverables">
      {
        service.deliverables.map((d) => (
          <li class="service-deliverable" data-reveal>
            <span class="service-check" aria-hidden="true">
              ✓
            </span>
            {d}
          </li>
        ))
      }
    </ul>
  </section>

  <section class="service-section" aria-labelledby="proceso" data-reveal-group>
    <h2 class="service-section-title" id="proceso" data-reveal>
      <span class="service-prompt" aria-hidden="true">$</span> cat proceso.md
    </h2>
    <ol class="service-process">
      {
        service.process.map((p, i) => (
          <li class="service-step" data-reveal>
            <span class="service-step-num" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div>
              <h3 class="service-step-title">{p.step}</h3>
              <p class="service-step-detail">{p.detail}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="service-section" aria-labelledby="faq" data-reveal-group>
    <h2 class="service-section-title" id="faq" data-reveal>
      <span class="service-prompt" aria-hidden="true">$</span> cat faq.md
    </h2>
    <dl class="service-faqs">
      {
        service.faqs.map((f) => (
          <div class="service-faq" data-reveal>
            <dt class="service-faq-q">{f.q}</dt>
            <dd class="service-faq-a">{f.a}</dd>
          </div>
        ))
      }
    </dl>
  </section>

  <section class="service-cta" data-reveal-group>
    <p class="service-cta-text" data-reveal>
      Cuéntame tu proyecto y te envío una propuesta con precio cerrado en menos de 48 horas.
    </p>
    <div class="service-cta-actions" data-reveal>
      <a class="btn-terminal btn-terminal--primary" href="/#contacto">
        <span class="bracket bracket-l" aria-hidden="true">[</span>
        pedir_presupuesto
        <span class="bracket bracket-r" aria-hidden="true">]</span>
      </a>
      <a class="btn-terminal" href="/servicios">
        <span class="bracket bracket-l" aria-hidden="true">←</span>
        ver_todos_los_servicios
      </a>
    </div>
  </section>
</article>

<style>
  .service-page {
    padding-block: clamp(7rem, 14vw, 10rem) 0;
  }

  .service-breadcrumb {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
  }
  .service-breadcrumb a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--duration-hover) ease;
  }
  .service-breadcrumb a:hover,
  .service-breadcrumb a:focus-visible {
    color: var(--color-white);
  }

  .service-title {
    margin: 0;
    font-size: var(--text-h2);
    font-weight: 700;
    letter-spacing: var(--text-h2--letter-spacing);
    line-height: var(--text-h2--line-height);
    color: var(--color-white);
  }
  .service-price {
    margin: 0.75rem 0 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-accent);
  }
  .service-answer {
    margin: 1.25rem 0 0;
    max-width: 640px;
    font-size: var(--text-body);
    line-height: var(--text-body--line-height);
    color: var(--color-text);
  }
  .service-header-cta {
    margin-top: 1.75rem;
  }

  .service-section {
    margin-top: clamp(3.5rem, 7vw, 5rem);
  }
  .service-section-title {
    margin: 0 0 1.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-white);
  }
  .service-prompt {
    color: var(--color-accent);
  }

  .service-deliverables {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
    max-width: 640px;
  }
  .service-deliverable {
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
    font-size: var(--text-body);
    line-height: 1.6;
    color: var(--color-text);
  }
  .service-check {
    font-family: var(--font-mono);
    color: var(--color-accent);
  }

  .service-process {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
    max-width: 640px;
  }
  .service-step {
    display: flex;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
    transition: border-color var(--duration-hover) ease;
  }
  .service-step:hover {
    border-color: var(--color-border-strong);
  }
  .service-step-num {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-accent);
  }
  .service-step-title {
    margin: 0 0 0.25rem;
    font-size: var(--text-body);
    font-weight: 600;
    color: var(--color-white);
  }
  .service-step-detail {
    margin: 0;
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-text);
  }

  .service-faqs {
    display: grid;
    gap: 1rem;
    margin: 0;
    max-width: 680px;
  }
  .service-faq {
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
  }
  .service-faq-q {
    margin: 0 0 0.5rem;
    font-size: var(--text-body);
    font-weight: 600;
    color: var(--color-white);
  }
  .service-faq-a {
    margin: 0;
    font-size: var(--text-sm);
    line-height: 1.65;
    color: var(--color-text);
  }

  .service-cta {
    display: grid;
    justify-items: start;
    gap: 1.25rem;
    margin-top: clamp(3.5rem, 7vw, 5rem);
    padding: 2rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
  }
  .service-cta-text {
    margin: 0;
    max-width: 480px;
    font-size: var(--text-body);
    line-height: var(--text-body--line-height);
    color: var(--color-text);
  }
  .service-cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
