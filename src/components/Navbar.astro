---
import { Image } from 'astro:assets';

import logo from '../assets/logo-mkcodev.png';
import { SITE, type Lang } from '../data/site';
import { alternatePath } from '../i18n/routes';
import { useTranslations } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const home = lang === 'es' ? '/' : '/en';
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const langTarget = alternatePath(path);

const leftLinks = [
  { href: `${home}#proyectos`, label: t('nav.projects'), kbd: 'g p' },
  { href: `${home}#como-trabajo`, label: t('nav.how'), kbd: 'g w' },
  { href: `${home}#trayectoria`, label: t('nav.timeline'), kbd: 'g t' },
];
const rightLinks = [
  { href: `${home}#sobre-mi`, label: t('nav.about'), kbd: 'g a' },
  { href: lang === 'es' ? '/uses' : '/en/uses', label: t('nav.uses'), kbd: 'g u' },
  { href: `${home}#contacto`, label: t('nav.contact'), kbd: 'g c' },
];
const allLinks = [...leftLinks, ...rightLinks];
const ctaLabel = lang === 'es' ? 'open to work' : 'open to work';
---

<header class="navbar" data-navbar>
  <nav class="navbar-bar glass" aria-label="principal">
    <div class="navbar-inner container-site">
      <ul class="navbar-links navbar-links--left">
        {
          leftLinks.map((link) => (
            <li>
              <a class="navbar-link" href={link.href}>
                <span class="navbar-link-dot" aria-hidden="true" />
                <span class="navbar-link-label">{link.label}</span>
                <span class="navbar-link-kbd" aria-hidden="true">
                  {link.kbd}
                </span>
              </a>
            </li>
          ))
        }
      </ul>

      <a href={home} class="navbar-logo" aria-label={SITE.name}>
        <svg class="navbar-logo-ring" viewBox="0 0 100 100" aria-hidden="true">
          <circle class="ring-track" cx="50" cy="50" r="47" fill="none" stroke-width="1.5"></circle>
          <circle
            class="ring-progress"
            data-nav-progress
            cx="50"
            cy="50"
            r="47"
            fill="none"
            stroke-width="1.5"
            pathLength="1"
            stroke-dasharray="1"
            stroke-dashoffset="1"
            transform="rotate(-90 50 50)"></circle>
        </svg>
        <span class="navbar-logo-face" data-nav-logo>
          <Image src={logo} alt="" width={144} height={144} loading="eager" />
        </span>
      </a>
      <span class="navbar-logo-spacer" aria-hidden="true"></span>

      <div class="navbar-right">
        <ul class="navbar-links navbar-links--right">
          {
            rightLinks.map((link) => (
              <li>
                <a class="navbar-link" href={link.href}>
                  <span class="navbar-link-dot" aria-hidden="true" />
                  <span class="navbar-link-label">{link.label}</span>
                  <span class="navbar-link-kbd" aria-hidden="true">
                    {link.kbd}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
        <a class="navbar-cta" href={`${home}#contacto`} data-magnetic>
          <span class="navbar-cta-dot" aria-hidden="true"></span>
          <span class="navbar-cta-label">{ctaLabel}</span>
          <span class="navbar-cta-brackets" aria-hidden="true">[ ↗ ]</span>
        </a>
        <a class="navbar-lang" href={langTarget} aria-label={t('nav.langLabel')} data-astro-reload>
          {lang === 'es' ? 'EN' : 'ES'}
        </a>
        <button
          type="button"
          class="navbar-menu-btn"
          data-menu-toggle
          aria-expanded="false"
          aria-controls="mega-menu"
          aria-label={t('nav.menuLabel')}
        >
          <span class="navbar-menu-icon" aria-hidden="true"></span>
        </button>
      </div>
    </div>
    <span class="navbar-hairline" data-nav-hairline aria-hidden="true"></span>
  </nav>

  <div class="mega-menu-backdrop" data-mega-backdrop aria-hidden="true"></div>
  <div class="mega-menu glass" id="mega-menu" data-mega-menu hidden>
    <div class="container-site mega-menu-grid">
      <ul class="mega-menu-links">
        {
          allLinks.map((link, i) => (
            <li style={`--i: ${i}`}>
              <a class="mega-menu-link" href={link.href} data-menu-close>
                <span class="mega-menu-index">0{i + 1}</span>
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="mega-menu-aside">
        <p class="mega-menu-badge">
          <span class="badge-dot" aria-hidden="true"></span>
          {t('nav.available')}
        </p>
        <a class="btn-terminal" href={SITE.cvPath} download>
          <span class="bracket bracket-l" aria-hidden="true">[</span>
          {t('nav.downloadCv').replace(/[[\]]/g, '').trim()}
          <span class="bracket bracket-r" aria-hidden="true">]</span>
        </a>
        <ul class="mega-menu-socials">
          <li><a href={SITE.github} rel="noopener" target="_blank">GitHub</a></li>
          <li><a href={SITE.linkedin} rel="noopener" target="_blank">LinkedIn</a></li>
          <li><a href={`mailto:${SITE.email}`}>Email</a></li>
        </ul>
      </div>
    </div>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 100;
  }
  .navbar-bar {
    position: relative;
    /* Nueva capa de apilamiento por encima del mega menu (que es hermano):
       sin esto, el mega menu tapa el logo cuando abre porque va después
       en el DOM. */
    z-index: 2;
    /* Empuja todo el bar 10px hacia abajo. Antes el offset vertical
       vivía en .navbar-logo (margin-top) y solo desplazaba el coin,
       dejando links + EN + menú 5px por encima de su centro. Con el
       padding aquí, todos los items del grid se alinean vertical dentro
       del mismo inner. */
    padding-top: 10px;
    border-inline: none;
    border-top: none;
    border-radius: 0;
  }
  .navbar-inner {
    position: relative;
    display: grid;
    /* Móvil: logo a la izquierda, controles a la derecha, hueco flexible
       en medio. Desktop (≥900px, ver media query más abajo) recupera el
       layout 1fr auto 1fr con el coin centrado y los links a los lados. */
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    height: 60px;
  }
  @media (min-width: 900px) {
    .navbar-inner {
      grid-template-columns: 1fr auto 1fr;
    }
  }

  .navbar-links {
    display: none;
    gap: 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  @media (min-width: 900px) {
    .navbar-links {
      display: flex;
    }
    .navbar-links--left {
      justify-content: flex-end;
    }
    .navbar-links--right {
      justify-content: flex-start;
    }
  }
  .navbar-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding-left: 12px;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--duration-hover) ease;
  }
  .navbar-link:hover,
  .navbar-link:focus-visible {
    color: var(--color-accent);
  }
  .navbar-link.is-active {
    color: var(--color-accent);
  }

  .navbar-link-dot {
    position: absolute;
    left: 0;
    top: 50%;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 6px var(--color-accent);
    transform: translate(-4px, -50%) scale(0);
    transition: transform 0.35s var(--ease-out-power3);
  }
  .navbar-link.is-active .navbar-link-dot,
  .navbar-link:hover .navbar-link-dot,
  .navbar-link:focus-visible .navbar-link-dot {
    transform: translate(-4px, -50%) scale(1);
  }

  .navbar-link-kbd {
    position: absolute;
    top: calc(100% + 6px);
    left: 12px;
    padding: 1px 5px;
    border: 1px solid var(--color-border-soft);
    border-radius: 3px;
    background: rgb(4 7 7 / 0.9);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transform: translateY(-4px);
    transition:
      opacity 0.22s ease,
      transform 0.22s var(--ease-out-power3);
  }
  .navbar-link:hover .navbar-link-kbd,
  .navbar-link:focus-visible .navbar-link-kbd {
    opacity: 1;
    transform: translateY(0);
  }
  @media (pointer: coarse) {
    .navbar-link-kbd {
      display: none;
    }
  }

  /* Logo-moneda: 72px de coin sobre navbar-inner de 60px = sobresale por
     arriba y por abajo. El margin-top empuja el coin ligeramente hacia
     abajo para respirar del borde superior de la ventana y desplazar el
     "poke" al lado de abajo (más visible sobre las secciones). */
  .navbar-logo {
    position: relative;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    overflow: visible;
    z-index: 2;
    /* Móvil: 1ª columna (izquierda). Desktop: columna central (coin
       flotando en medio con los grupos de links a cada lado). */
    grid-column: 1;
    justify-self: start;
    margin-top: 10px;
    transition: filter var(--duration-hover) ease;
  }
  @media (min-width: 900px) {
    .navbar-logo {
      grid-column: 2;
      justify-self: center;
    }
  }
  .navbar-logo-face {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--color-bg);
    border: 1px solid var(--color-border-soft);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    display: grid;
    place-items: center;
    transform-origin: 50% 50%;
    will-change: transform;
  }
  .navbar-logo-face img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    scale: 1.06;
  }
  .navbar-logo:hover .navbar-logo-face {
    box-shadow: var(--shadow-glow);
  }

  /* El grid ya reserva la columna del logo — el spacer legacy queda como no-op */
  .navbar-logo-spacer {
    display: none;
  }

  .navbar-logo-ring {
    position: absolute;
    inset: -6px;
    width: calc(100% + 12px);
    height: calc(100% + 12px);
    pointer-events: none;
    z-index: 1;
  }
  .ring-track {
    stroke: var(--color-border-soft);
    opacity: 0.5;
  }
  .ring-progress {
    stroke: var(--color-accent);
    filter: drop-shadow(0 0 4px rgb(0 219 213 / 0.6));
    transition: stroke-dashoffset 140ms linear;
  }

  .navbar-hairline {
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--color-accent) 50%, transparent 100%);
    transform: translateX(-50%) scaleX(1);
    transform-origin: 50% 50%;
    opacity: 0.55;
    pointer-events: none;
  }

  .navbar-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
    white-space: nowrap;
    /* Mismo motivo que .navbar-logo: forzar col 3 para que en móvil
       EN + menu queden pegados al borde derecho en vez de junto al logo. */
    grid-column: 3;
  }

  .navbar-cta {
    display: none;
    align-items: center;
    gap: 0.4rem;
    padding: 6px 10px;
    white-space: nowrap;
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-sm);
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    text-decoration: none;
    background: transparent;
    transition:
      color var(--duration-hover) ease,
      border-color var(--duration-hover) ease,
      box-shadow var(--duration-hover) ease;
  }
  @media (min-width: 780px) {
    .navbar-cta {
      display: inline-flex;
    }
  }
  .navbar-cta:hover,
  .navbar-cta:focus-visible {
    color: var(--color-accent);
    border-color: var(--color-accent);
    box-shadow: 0 0 0 1px rgb(0 219 213 / 0.35) inset;
  }
  .navbar-cta-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #3ddc84;
    box-shadow: 0 0 6px rgb(61 220 132 / 0.8);
    animation: pulse-dot 2s ease-in-out infinite;
  }
  .navbar-cta-brackets {
    color: var(--color-accent);
    transition: transform var(--duration-hover) var(--ease-out-power3);
  }
  .navbar-cta:hover .navbar-cta-brackets,
  .navbar-cta:focus-visible .navbar-cta-brackets {
    transform: translateX(3px);
  }

  .navbar-lang {
    /* Misma altura que el botón de menú (36px) para que ambos controles
       ocupen la misma línea vertical dentro del navbar de 60px. */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 36px;
    min-width: 36px;
    padding: 0 0.6rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1;
    color: var(--color-muted);
    text-decoration: none;
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-sm);
    transition:
      color var(--duration-hover) ease,
      border-color var(--duration-hover) ease;
  }
  .navbar-lang:hover,
  .navbar-lang:focus-visible {
    color: var(--color-accent);
    border-color: var(--color-accent-dark);
  }

  .navbar-menu-btn {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .navbar-menu-icon,
  .navbar-menu-icon::before,
  .navbar-menu-icon::after {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--color-text);
    transition:
      transform var(--duration-hover) var(--ease-out-power3),
      opacity var(--duration-hover) ease;
  }
  .navbar-menu-icon::before,
  .navbar-menu-icon::after {
    content: '';
    position: relative;
  }
  .navbar-menu-icon::before {
    top: -6px;
  }
  .navbar-menu-icon::after {
    top: 4.5px;
  }
  .navbar-menu-btn[aria-expanded='true'] .navbar-menu-icon {
    background: transparent;
  }
  .navbar-menu-btn[aria-expanded='true'] .navbar-menu-icon::before {
    transform: translateY(6px) rotate(45deg);
  }
  .navbar-menu-btn[aria-expanded='true'] .navbar-menu-icon::after {
    /* -6px (no -7.5): con -7.5 las barras del aspa cruzaban 1.5px por
       encima del centro del botón. -6 exacto compensa el offset natural
       (top: 4.5) más la altura de la línea central (1.5) para caer en el
       mismo eje que la barra rotada de ::before. */
    transform: translateY(-6px) rotate(-45deg);
  }

  /* ---------- Mega menu ---------- */
  /* Backdrop: cubre TODA la ventana detrás del panel para que el H1 del
     hero no compita con los links. Se activa vía data-open="1" desde el
     mismo toggle del mega menu. */
  .mega-menu-backdrop {
    position: fixed;
    inset: 0;
    z-index: 1;
    background: rgb(10 15 15 / 0.72);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease-out;
  }
  .mega-menu-backdrop[data-open='1'] {
    opacity: 1;
    pointer-events: auto;
  }
  .mega-menu {
    position: relative;
    z-index: 2;
    border-inline: none;
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    background: rgb(10 15 15 / 0.85);
  }
  .mega-menu-grid {
    display: grid;
    gap: 2rem;
    padding-block: 2rem;
  }
  @media (min-width: 900px) {
    .mega-menu-grid {
      grid-template-columns: 1fr auto;
      gap: 4rem;
      padding-block: 2.5rem;
    }
  }
  .mega-menu-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.25rem;
  }
  @media (min-width: 700px) {
    .mega-menu-links {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .mega-menu-link {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-display);
    font-size: var(--text-h3);
    color: var(--color-text);
    text-decoration: none;
    transition:
      color var(--duration-hover) ease,
      background-color var(--duration-hover) ease;
  }
  .mega-menu-link:hover,
  .mega-menu-link:focus-visible {
    color: var(--color-accent);
    background: rgb(255 255 255 / 0.03);
  }
  .mega-menu-index {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent-dark);
  }

  .mega-menu-aside {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
  }
  .mega-menu-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.04em;
  }
  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #3ddc84;
    box-shadow: 0 0 8px rgb(61 220 132 / 0.7);
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }
  .mega-menu-socials {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1.25rem;
  }
  .mega-menu-socials a {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--duration-hover) ease;
  }
  .mega-menu-socials a:hover,
  .mega-menu-socials a:focus-visible {
    color: var(--color-accent);
  }
</style>

<script>
  // Delegación a nivel de documento: sobrevive a los swaps de View Transitions.
  let open = false;

  function els(): { menu: HTMLElement; btn: HTMLElement; backdrop: HTMLElement | null } | null {
    const menu = document.querySelector<HTMLElement>('[data-mega-menu]');
    const btn = document.querySelector<HTMLElement>('[data-menu-toggle]');
    const backdrop = document.querySelector<HTMLElement>('[data-mega-backdrop]');
    return menu && btn ? { menu, btn, backdrop } : null;
  }

  async function setOpen(next: boolean): Promise<void> {
    const found = els();
    if (!found) return;
    const { menu, btn, backdrop } = found;
    open = next;
    btn.setAttribute('aria-expanded', String(next));
    if (backdrop) backdrop.dataset['open'] = next ? '1' : '0';

    // Import dinámico: gsap no entra en el bundle eager del navbar (TBT).
    const { default: gsap } = await import('gsap');
    if (open !== next) return; // otro toggle ganó durante el await

    if (next) {
      menu.hidden = false;
      gsap.fromTo(
        menu,
        { opacity: 0, y: -12 },
        { opacity: 1, y: 0, duration: 0.4, ease: 'power3.out' },
      );
      gsap.fromTo(
        menu.querySelectorAll('li'),
        { opacity: 0, y: 10 },
        { opacity: 1, y: 0, duration: 0.4, ease: 'power3.out', stagger: 0.06, delay: 0.05 },
      );
    } else {
      gsap.to(menu, {
        opacity: 0,
        y: -12,
        duration: 0.3,
        ease: 'power2.in',
        onComplete: () => {
          menu.hidden = true;
        },
      });
    }
  }

  document.addEventListener('click', (e) => {
    const target = e.target as Element;
    if (target.closest('[data-menu-toggle]')) {
      void setOpen(!open);
      return;
    }
    if (target.closest('[data-menu-close]') || (open && !target.closest('[data-mega-menu]'))) {
      void setOpen(false);
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && open) {
      void setOpen(false);
      (document.querySelector('[data-menu-toggle]') as HTMLElement | null)?.focus();
    }
  });

  document.addEventListener('astro:before-swap', () => {
    open = false;
  });
</script>
