---
interface Props {
  marker: string;
  title: string;
  id?: string;
  /** false = sin reveal por scroll (necesario dentro de secciones pinned) */
  animate?: boolean;
}

const { marker, title, id, animate = true } = Astro.props;
---

<div class="section-heading" data-animate={animate ? 'section-heading' : undefined}>
  <p class="section-marker" data-animate-marker>{marker}</p>
  <h2 id={id} class="section-title" data-animate-title>{title}</h2>
</div>

<style>
  .section-heading {
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }
  .section-marker {
    margin: 0 0 0.75rem;
  }
  .section-title {
    margin: 0;
    font-size: var(--text-h2);
    font-weight: 700;
    letter-spacing: var(--text-h2--letter-spacing);
    line-height: var(--text-h2--line-height);
    color: var(--color-white);
  }
  /* Word split reveal (reveal.ts wrapWords): cada palabra vive en
     .mask (overflow hidden) y sube desde abajo con clip-path. inline-block
     mantiene el flujo natural. `padding-bottom` da margen al descender de
     letras (g, y, j) para que el clip no las corte. */
  .section-title :global(.mask) {
    display: inline-block;
    overflow: hidden;
    line-height: inherit;
    padding-bottom: 0.12em;
    margin-bottom: -0.12em;
    vertical-align: bottom;
  }
  .section-title :global(.word) {
    display: inline-block;
    will-change: transform, clip-path;
  }
</style>
