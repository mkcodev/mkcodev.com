---
import { ClientRouter } from 'astro:transitions';
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/jetbrains-mono';
import spaceGroteskUrl from '@fontsource-variable/space-grotesk/files/space-grotesk-latin-wght-normal.woff2?url';
import jetbrainsMonoUrl from '@fontsource-variable/jetbrains-mono/files/jetbrains-mono-latin-wght-normal.woff2?url';

import '../styles/global.css';
import { SITE, SITE_URL, type Lang } from '../data/site';
import { personNode, professionalServiceNode, websiteNode, type SchemaNode } from '../data/schema';
import { hreflangPair, isEsOnly } from '../i18n/routes';
import { useTranslations } from '../i18n/ui';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ShortcutsOverlay from '../components/ShortcutsOverlay.astro';
import CommandPalette from '../components/islands/CommandPalette.tsx';
import CodiChat from '../components/islands/codi/CodiChat.tsx';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  ogImage?: string;
  noIndex?: boolean;
  /** Nodos JSON-LD adicionales de la página (webPage, breadcrumbs, faq…). */
  schema?: SchemaNode[];
}

const {
  lang,
  title,
  description,
  ogImage = SITE.ogImage,
  noIndex = false,
  schema = [],
} = Astro.props;
const t = useTranslations(lang);

const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const canonical = new URL(path === '/' ? '/' : path, SITE_URL).href;
// Las páginas ES-only (servicios, ubicaciones, posts, legales) no llevan
// hreflang: una página monolingüe solo necesita canonical.
const pair = isEsOnly(path) ? null : hreflangPair(path);
const ogImageAbs = new URL(ogImage, SITE_URL).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [personNode(), professionalServiceNode(), websiteNode(lang), ...schema],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />
    <meta name="theme-color" content={SITE.themeColor} />
    {noIndex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    {
      pair && (
        <>
          <link rel="alternate" hreflang="es" href={new URL(pair.es, SITE_URL).href} />
          <link rel="alternate" hreflang="en" href={new URL(pair.en, SITE_URL).href} />
          <link rel="alternate" hreflang="x-default" href={new URL(pair.es, SITE_URL).href} />
        </>
      )
    }
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="preload" href={spaceGroteskUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={jetbrainsMonoUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/jbm-symbols.woff2" as="font" type="font/woff2" crossorigin />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-link">{t('skip.content')}</a>
    <canvas class="glyph-tunnel" data-glyph-tunnel="left" aria-hidden="true"></canvas>
    <canvas class="glyph-tunnel glyph-tunnel--right" data-glyph-tunnel="right" aria-hidden="true"
    ></canvas>
    <Navbar lang={lang} />
    <main id="main-content">
      <slot />
    </main>
    <Footer lang={lang} />
    <ShortcutsOverlay lang={lang} />
    <CommandPalette client:idle lang={lang} transition:persist="cmdk" />
    <div data-codi-orb transition:persist="codi-orb" class="codi-orb-wrapper"></div>
    <CodiChat client:idle lang={lang} transition:persist="codi" />
    <script src="../scripts/app.ts"></script>
  </body>
</html>
