---
import Base from '../layouts/Base.astro';
import Hero from '../components/sections/Hero.astro';
import StackMarquee from '../components/StackMarquee.astro';
import Constellation from '../components/Constellation.astro';
import Projects from '../components/sections/Projects.astro';
import Bento from '../components/sections/Bento.astro';
import Timeline from '../components/sections/Timeline.astro';
import About from '../components/sections/About.astro';
import Certs from '../components/sections/Certs.astro';
import Contact from '../components/sections/Contact.astro';
import { useTranslations } from '../i18n/ui';

const lang = 'es' as const;
const t = useTranslations(lang);
---

<Base lang={lang} title={t('meta.home.title')} description={t('meta.home.description')}>
  <Hero lang={lang} />

  <StackMarquee />

  <Constellation lang={lang} />

  <Projects lang={lang} />

  <Bento lang={lang} />

  <Timeline lang={lang} />

  <About lang={lang} />

  <Certs lang={lang} />

  <Contact lang={lang} />
</Base>
