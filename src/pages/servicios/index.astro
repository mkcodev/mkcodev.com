---
import Base from '../../layouts/Base.astro';
import { services, formatPrice } from '../../data/services';
import { SITE_URL } from '../../data/site';
import { webPageNode, breadcrumbList } from '../../data/schema';

const lang = 'es' as const;
const title = 'Servicios de diseño web, SEO e IA | mkcodev';
const description =
  'Diseño web a medida, tiendas online, SEO, mantenimiento, IA y marca personal. Precios claros desde el primer día. Bilbao, Gran Bilbao y Zamora.';
const url = `${SITE_URL}/servicios`;

const schema = [
  webPageNode({ url, title, description, lang, aboutBusiness: true }),
  breadcrumbList([
    { name: 'Inicio', url: SITE_URL },
    { name: 'Servicios', url },
  ]),
];

const unitLabel = (u: 'proyecto' | 'mes') => (u === 'mes' ? '€/mes' : '€');
---

<Base
  lang={lang}
  title={title}
  description={description}
  ogImage="/og/servicios.png"
  schema={schema}
>
  <div class="container-site services-page">
    <header class="services-header" data-reveal-group>
      <p class="services-marker" data-reveal>~/servicios</p>
      <h1 class="services-title" data-reveal>Servicios</h1>
      <p class="services-intro" data-reveal>
        Diseño y desarrollo web a medida, tiendas online, SEO, mantenimiento, soluciones de IA y
        marca personal para negocios de Bilbao, el Gran Bilbao y Zamora. Trabajo con código moderno
        (Astro, Next.js, React), precios cerrados antes de empezar y trato directo: hablas siempre
        con quien construye tu web.
      </p>
    </header>

    <div class="services-grid" data-reveal-group>
      {
        services.map((s) => (
          <a class="service-card" href={`/servicios/${s.slug}`} data-reveal>
            <h2 class="service-card-title">
              <span class="service-prompt" aria-hidden="true">
                $
              </span>{' '}
              {s.shortTitle}
            </h2>
            <p class="service-card-desc">{s.cardDesc}</p>
            <p class="service-card-price">
              desde {formatPrice(s.priceFrom)}
              {unitLabel(s.priceUnit)}
            </p>
            <span class="service-card-arrow" aria-hidden="true">
              →
            </span>
          </a>
        ))
      }
    </div>

    <section class="services-pricing" aria-labelledby="precios" data-reveal-group>
      <h2 class="services-pricing-title" id="precios" data-reveal>
        <span class="service-prompt" aria-hidden="true">$</span> cat precios.md
      </h2>
      <p class="services-pricing-note" data-reveal>
        Precios orientativos por rango. Cada proyecto se presupuesta y se cierra por escrito antes
        de empezar, sin sorpresas.
      </p>
      <div class="services-table-wrap" data-reveal>
        <table class="services-table">
          <thead>
            <tr>
              <th scope="col">Servicio</th>
              <th scope="col">Desde</th>
              <th scope="col">Hasta</th>
              <th scope="col">Modalidad</th>
            </tr>
          </thead>
          <tbody>
            {
              services.map((s) => (
                <tr>
                  <th scope="row">
                    <a href={`/servicios/${s.slug}`}>{s.title}</a>
                  </th>
                  <td>{formatPrice(s.priceFrom)}€</td>
                  <td>{formatPrice(s.priceTo)}€</td>
                  <td>{s.priceUnit === 'mes' ? 'cuota mensual' : 'precio por proyecto'}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    <section class="services-cta" data-reveal-group>
      <p class="services-cta-text" data-reveal>
        ¿No sabes qué necesita tu negocio? Cuéntamelo y te digo por dónde empezar, sin compromiso.
      </p>
      <a class="btn-terminal btn-terminal--primary" href="/#contacto" data-reveal>
        <span class="bracket bracket-l" aria-hidden="true">[</span>
        pedir_presupuesto
        <span class="bracket bracket-r" aria-hidden="true">]</span>
      </a>
    </section>
  </div>
</Base>

<style>
  .services-page {
    padding-block: clamp(7rem, 14vw, 10rem) 0;
  }

  .services-marker {
    margin: 0 0 0.75rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
  }
  .services-title {
    margin: 0;
    font-size: var(--text-h2);
    font-weight: 700;
    letter-spacing: var(--text-h2--letter-spacing);
    line-height: var(--text-h2--line-height);
    color: var(--color-white);
  }
  .services-intro {
    margin: 1.25rem 0 0;
    max-width: 640px;
    font-size: var(--text-body);
    line-height: var(--text-body--line-height);
    color: var(--color-text);
  }

  .services-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
    margin-top: clamp(2.5rem, 6vw, 4rem);
  }
  @media (min-width: 700px) {
    .services-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (min-width: 1100px) {
    .services-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .service-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition:
      border-color var(--duration-hover) ease,
      transform var(--duration-hover) ease;
  }
  .service-card:hover,
  .service-card:focus-visible {
    border-color: var(--color-accent-border);
    transform: translateY(-2px);
  }
  .service-card:active {
    transform: translateY(0);
  }
  .service-card-title {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-white);
  }
  .service-prompt {
    color: var(--color-accent);
  }
  .service-card-desc {
    margin: 0;
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-text);
  }
  .service-card-price {
    margin: auto 0 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
  }
  .service-card-arrow {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    font-family: var(--font-mono);
    color: var(--color-muted);
    transition:
      color var(--duration-hover) ease,
      transform var(--duration-hover) ease;
  }
  .service-card:hover .service-card-arrow {
    color: var(--color-accent);
    transform: translateX(3px);
  }

  .services-pricing {
    margin-top: clamp(4rem, 8vw, 6rem);
  }
  .services-pricing-title {
    margin: 0 0 0.75rem;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-white);
  }
  .services-pricing-note {
    margin: 0 0 1.5rem;
    max-width: 560px;
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-muted);
  }
  .services-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
    background: var(--color-surface);
  }
  .services-table {
    width: 100%;
    min-width: 560px;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }
  .services-table th,
  .services-table td {
    padding: 0.875rem 1.25rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border-soft);
  }
  .services-table thead th {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .services-table tbody tr:last-child th,
  .services-table tbody tr:last-child td {
    border-bottom: none;
  }
  .services-table tbody th {
    font-weight: 600;
    color: var(--color-white);
  }
  .services-table tbody th a {
    color: inherit;
    text-decoration: none;
    transition: color var(--duration-hover) ease;
  }
  .services-table tbody th a:hover,
  .services-table tbody th a:focus-visible {
    color: var(--color-accent);
  }
  .services-table td {
    font-family: var(--font-mono);
    color: var(--color-text);
  }

  .services-cta {
    display: grid;
    justify-items: start;
    gap: 1.25rem;
    margin-top: clamp(4rem, 8vw, 6rem);
    padding: 2rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
  }
  .services-cta-text {
    margin: 0;
    max-width: 480px;
    font-size: var(--text-body);
    line-height: var(--text-body--line-height);
    color: var(--color-text);
  }
</style>
